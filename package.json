{
  "name": "vidsubkh",
  "version": "1.0.0",
  "description": "YouTube Downloader & AI Voice Translator with Khmer support",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "setup": "node scripts/setup.js"
  },
  "build": {
    "appId": "com.vidsubkh.app",
    "productName": "VidSubKh",
    "icon": "src/renderer/assets/icon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "python/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "python/",
        "to": "python/"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "src/renderer/assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "src/renderer/assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "src/renderer/assets/icon.png"
    }
  },
  "keywords": ["youtube", "downloader", "ai", "translator", "khmer", "subtitle"],
  "author": "VidSubKh",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "electron-store": "^8.1.0",
    "form-data": "^4.0.0",
    "uuid": "^9.0.1"
  }
}
